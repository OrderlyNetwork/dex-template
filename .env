# =============================================================================
# Orderly DEX Template Configuration
# =============================================================================
# Every config in this file can also be overridden at runtime via public/config.js
# (no rebuild needed). See app/utils/runtime-config.ts for the loading logic.
# Boolean values: "true" or "false" (as strings).
# =============================================================================

# -----------------------------------------------------------------------------
# [REQUIRED] Broker Identity
# -----------------------------------------------------------------------------
# Your Orderly broker ID (provided by Orderly). Use "demo" for the sandbox.
VITE_ORDERLY_BROKER_ID=demo

# Display name shown in the nav bar, PnL share cards, footer, and page titles.
VITE_ORDERLY_BROKER_NAME=Demo

# -----------------------------------------------------------------------------
# App Meta
# -----------------------------------------------------------------------------
# Browser tab title and PWA name. Falls back to "Orderly DEX" in manifest.
VITE_APP_NAME=Orderly Demo

# Short description used in meta tags and PWA manifest.
VITE_APP_DESCRIPTION=Orderly Demo

# -----------------------------------------------------------------------------
# Network & Chains
# -----------------------------------------------------------------------------
# Set to "true" to hide the mainnet/testnet toggle and lock to one network.
# If both are false (default), the user can switch between mainnet and testnet.
# VITE_DISABLE_MAINNET=false
# VITE_DISABLE_TESTNET=false

# Comma-separated chain IDs to whitelist (replaces the default full list).
# E.g. "42161,10,8453" for Arbitrum, Optimism, Base.
# VITE_ORDERLY_MAINNET_CHAINS=42161,10,8453
# VITE_ORDERLY_TESTNET_CHAINS=421614,11155420,84532

# Default chain on first load (chain ID integer, e.g. 42161 for Arbitrum).
# VITE_DEFAULT_CHAIN=42161

# -----------------------------------------------------------------------------
# Navigation Menus
# -----------------------------------------------------------------------------
# Comma-separated list of enabled menus. Order matters.
# Available: Trading, Portfolio, Markets, Swap, Leaderboard, Campaigns,
#            Rewards, Vaults, Points
# Default (if unset): Trading, Portfolio, Markets, Swap, Leaderboard, Campaigns
# VITE_ENABLED_MENUS=Trading,Portfolio,Markets,Swap,Leaderboard,Campaigns

# External links appended to the nav bar. Format: "Name,URL;Name,URL"
# Example: "Docs,https://docs.example.com;Blog,https://blog.example.com"
# VITE_CUSTOM_MENUS=

# Set to "true" to show the $ORDER campaigns dropdown in the nav.
# VITE_ENABLE_CAMPAIGNS=false

# -----------------------------------------------------------------------------
# Logos & Branding
# -----------------------------------------------------------------------------
# Set to "true" if you've placed custom logos in public/:
#   public/logo.webp        - primary logo (desktop nav)
#   public/logo-secondary.webp - secondary logo (mobile nav)
# VITE_HAS_PRIMARY_LOGO=false
# VITE_HAS_SECONDARY_LOGO=false

# -----------------------------------------------------------------------------
# Social / Footer Links
# -----------------------------------------------------------------------------
# VITE_TELEGRAM_URL=
# VITE_DISCORD_URL=
# VITE_TWITTER_URL=

# -----------------------------------------------------------------------------
# WalletConnect
# -----------------------------------------------------------------------------
# Required for WalletConnect modal. Get one at https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# Privy (optional auth provider)
# -----------------------------------------------------------------------------
# If set, Privy is used instead of the default wallet connector.
# Sign up at https://privy.io
# VITE_PRIVY_APP_ID=

# Comma-separated login methods. Available: email, passkey, twitter, google
# Default (if unset): email
# VITE_PRIVY_LOGIN_METHODS=email

# URL to your terms of use (shown in Privy auth flow).
# VITE_PRIVY_TERMS_OF_USE=

# Set to "true" to enable Abstract smart-wallet via Privy.
# VITE_ENABLE_ABSTRACT_WALLET=false

# Set to "true" to disable EVM or Solana wallets in the Privy connector.
# VITE_DISABLE_EVM_WALLETS=false
# VITE_DISABLE_SOLANA_WALLETS=false

# -----------------------------------------------------------------------------
# TradingView Chart
# -----------------------------------------------------------------------------
# JSON object for chart color overrides. Keys: upColor, downColor, pnlUpColor,
# pnlDownColor, chartBG. Values are hex colors.
# Example: {"upColor":"#29E0A9","downColor":"#F5618B"}
# VITE_TRADING_VIEW_COLOR_CONFIG=

# -----------------------------------------------------------------------------
# PnL Sharing
# -----------------------------------------------------------------------------
# Set to "true" to use custom poster backgrounds from public/pnl/.
# VITE_USE_CUSTOM_PNL_POSTERS=false

# Number of custom poster images (poster_bg_1.webp .. poster_bg_N.webp) in public/pnl/.
# Default: 4
# VITE_CUSTOM_PNL_POSTER_COUNT=4

# -----------------------------------------------------------------------------
# SEO / Open Graph
# -----------------------------------------------------------------------------
# VITE_SEO_SITE_NAME=
# VITE_SEO_SITE_DESCRIPTION=
# VITE_SEO_SITE_URL=
# VITE_SEO_SITE_LANGUAGE=en
# VITE_SEO_SITE_LOCALE=en_US
# VITE_SEO_TWITTER_HANDLE=
# VITE_SEO_THEME_COLOR=
# VITE_SEO_KEYWORDS=

# -----------------------------------------------------------------------------
# Languages / i18n
# -----------------------------------------------------------------------------
# Comma-separated list of enabled locale codes.
# Available: en, zh, ja, es, ko, vi, de, fr, ru, id, tr, it, pt, uk, pl, nl
# Default: en
# VITE_AVAILABLE_LANGUAGES=en

# -----------------------------------------------------------------------------
# Symbol Filter
# -----------------------------------------------------------------------------
# Comma-separated list of trading symbols to whitelist. If empty, all symbols
# are shown. Example: "PERP_BTC_USDC,PERP_ETH_USDC,PERP_SOL_USDC"
# VITE_SYMBOL_LIST=

# -----------------------------------------------------------------------------
# Swap (WooFi Widget)
# -----------------------------------------------------------------------------
# Your broker EOA address (for WooFi swap referral / fee sharing).
# VITE_BROKER_EOA_ADDRESS=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# Raw HTML <script> tag(s) to inject into the page head (e.g. Google Analytics).
# Example: "<script src='https://www.googletagmanager.com/gtag/js?id=G-XXX'></script>"
# VITE_ANALYTICS_SCRIPT=

# -----------------------------------------------------------------------------
# Service Disclaimer Dialog
# -----------------------------------------------------------------------------
# Set to "true" to show a one-time disclaimer on first visit.
# VITE_ENABLE_SERVICE_DISCLAIMER_DIALOG=false

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
# Base URL path for deployments in subdirectories (e.g. "/my-dex/" for
# GitHub Pages at username.github.io/my-dex/). Default: "/"
# VITE_BASE_URL=/

# -----------------------------------------------------------------------------
# Geo-restriction
# -----------------------------------------------------------------------------
# Comma-separated list of restricted region codes (ISO 3166-1 alpha-2).
# Example: "US,CN,KP"
# VITE_RESTRICTED_REGIONS=
